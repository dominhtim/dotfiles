# ~/.zshrc — managed by chezmoi. Edit the source with `chezmoi edit ~/.zshrc`,
# not this file directly (your edits would be overwritten on the next `chezmoi apply`).
# Machine-specific stuff that shouldn't go in git at all still goes in ~/.zshrc.local.

# Powerlevel10k instant prompt. Must stay near the top of the file.
# Anything that reads input (password prompts, [y/n]) must go ABOVE this block.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

export PATH="$HOME/.local/bin:$PATH"   # chezmoi itself lives here
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="powerlevel10k/powerlevel10k"

# --- completion ---
autoload -U compinit
zstyle ':completion:*' menu select
zmodload zsh/complist
compinit
_comp_options+=(globdots)            # include dotfiles in tab-completion

DISABLE_UPDATE_PROMPT="true"
export UPDATE_ZSH_DAYS=13
ENABLE_CORRECTION="true"

plugins=(
  git
  sudo                                # press Esc twice to re-run last command with sudo
  extract                             # `extract <archive>` — one command for zip/tar/rar/whatever
  fzf
  zsh-autosuggestions
  zsh-syntax-highlighting             # must stay LAST in this list, it breaks bindings of anything after it
)

source $ZSH/oh-my-zsh.sh

# --- history ---
HISTFILE="$HOME/.zsh_history"
HISTSIZE=50000
SAVEHIST=50000
setopt EXTENDED_HISTORY          # save timestamps
setopt HIST_EXPIRE_DUPS_FIRST
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE         # don't record lines starting with a space
setopt HIST_VERIFY
setopt SHARE_HISTORY             # share history across open sessions

# --- editor ---
export EDITOR='nvim'
export VISUAL='nvim'

# --- aliases ---
alias ls='ls -Fh --color=auto'
alias la='ls -A'
alias ll='ls -lAh'
alias cp='cp -iv --reflink=auto'
alias mv='mv -iv'
alias rm='rm -v'
alias mkdir='mkdir -pv'
alias grep='grep --color=auto'
alias ..='cd ..'
alias ...='cd ../..'
alias vim='nvim'
alias vi='nvim'
alias reload='exec zsh'
alias dotfiles='chezmoi cd'

{{- /* This block is the actual payoff of moving to chezmoi templating: one repo,
       one alias, correct on every OS it's applied to. Add more `{{ if }}` blocks
       here as you add machines that need to differ (hostname, distro, etc). */}}
{{- if eq .chezmoi.os "darwin" }}
alias pbc='pbcopy'
alias pbp='pbpaste'
{{- else }}
alias pbc='xclip -selection clipboard'
alias pbp='xclip -selection clipboard -o'
{{- end }}

# --- fzf keybindings (Ctrl+R history, Ctrl+T files) — path differs by distro, try both ---
[ -f /usr/share/doc/fzf/examples/key-bindings.zsh ] && source /usr/share/doc/fzf/examples/key-bindings.zsh
[ -f /usr/share/fzf/key-bindings.zsh ] && source /usr/share/fzf/key-bindings.zsh

# --- prompt ---
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# --- local machine overrides, never committed ---
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local
