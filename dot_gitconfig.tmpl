# ~/.gitconfig — managed by chezmoi. name/email below come from chezmoi's
# stored data (set once during `chezmoi init`, see .chezmoi.toml.tmpl).
[user]
	name  = {{ .name }}
	email = {{ .email }}

[init]
	defaultBranch = main

[core]
	editor = nvim
	autocrlf = input
	excludesfile = ~/.gitignore_global

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[fetch]
	prune = true

[color]
	ui = auto

[merge]
	conflictstyle = diff3

[diff]
	colorMoved = default

[alias]
	st = status -sb
	co = checkout
	br = branch
	ci = commit
	last = log -1 HEAD
	lg = log --oneline --graph --decorate --all
	unstage = restore --staged
	amend = commit --amend --no-edit
	undo = reset --soft HEAD~1
